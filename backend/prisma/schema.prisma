generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AnalyticsSkillResults {
  Id             Int           @id @default(autoincrement())
  StudentExamId  Int?
  SkillId        Int?
  TotalQuestions Int?
  CorrectAnswers Int?
  Accuracy       Decimal?
  Skills         Skills?       @relation(fields: [SkillId], references: [SkillId], onDelete: NoAction, onUpdate: NoAction)
  StudentExams   StudentExams? @relation(fields: [StudentExamId], references: [StudentExamId], onDelete: NoAction, onUpdate: NoAction)
}

model AnalyticsTopicResults {
  Id             Int           @id @default(autoincrement())
  StudentExamId  Int?
  TopicId        Int?
  TotalQuestions Int?
  CorrectAnswers Int?
  Accuracy       Decimal?
  StudentExams   StudentExams? @relation(fields: [StudentExamId], references: [StudentExamId], onDelete: NoAction, onUpdate: NoAction)
  Topics         Topics?       @relation(fields: [TopicId], references: [TopicId], onDelete: NoAction, onUpdate: NoAction)
}

model AnswerLogs {
  LogId             Int               @id @default(autoincrement())
  AttemptQuestionId Int?
  ActionType        String?
  SelectedOption    String?
  CreatedAt         DateTime?         @default(now())
  AttemptQuestions  AttemptQuestions? @relation(fields: [AttemptQuestionId], references: [AttemptQuestionId], onDelete: NoAction, onUpdate: NoAction)
}

model AttemptQuestions {
  AttemptQuestionId  Int              @id @default(autoincrement())
  StudentExamId      Int?
  QuestionId         Int?
  StartTime          DateTime?
  EndTime            DateTime?
  TimeSpent          Int?
  AnswerChangedCount Int?
  IsCorrect          Boolean?
  AnswerLogs         AnswerLogs[]
  Questions          Questions?       @relation(fields: [QuestionId], references: [QuestionId], onDelete: NoAction, onUpdate: NoAction)
  StudentExams       StudentExams?    @relation(fields: [StudentExamId], references: [StudentExamId], onDelete: NoAction, onUpdate: NoAction)
  StudentAnswers     StudentAnswers[]
}

model DifficultyLevels {
  DifficultyId Int         @id @default(autoincrement())
  LevelName    String?
  Questions    Questions[]
}

model ExamBehaviorLogs {
  Id            Int           @id @default(autoincrement())
  StudentExamId Int?
  EventType     String?
  EventTime     DateTime?     @default(now())
  StudentExams  StudentExams? @relation(fields: [StudentExamId], references: [StudentExamId], onDelete: NoAction, onUpdate: NoAction)
}

model ExamQuestions {
  Id            Int        @id @default(autoincrement())
  ExamId        Int?
  QuestionId    Int?
  Part          Int?
  QuestionOrder Int?
  Exams         Exams?     @relation(fields: [ExamId], references: [ExamId], onDelete: NoAction, onUpdate: NoAction)
  Questions     Questions? @relation(fields: [QuestionId], references: [QuestionId], onDelete: NoAction, onUpdate: NoAction)
}

model Exams {
  ExamId        Int             @id @default(autoincrement())
  ExamName      String?
  Duration      Int?
  CreatedAt     DateTime?       @default(now())
  IsActive      Boolean?
  ExamQuestions ExamQuestions[]
  StudentExams  StudentExams[]
  ExamCode      String?
}

model QuestionImages {
  ImageId      Int        @id @default(autoincrement())
  QuestionId   Int?
  ImageUrl     String?
  Caption      String?
  DisplayOrder Int?
  Questions    Questions? @relation(fields: [QuestionId], references: [QuestionId], onDelete: NoAction, onUpdate: NoAction)
}

model QuestionOptions {
  OptionId      Int        @id @default(autoincrement())
  QuestionId    Int?
  OptionLabel   String?
  OptionContent String?
  IsCorrect     Boolean?
  Questions     Questions? @relation(fields: [QuestionId], references: [QuestionId], onDelete: NoAction, onUpdate: NoAction)
}

model Questions {
  QuestionId          Int                   @id @default(autoincrement())
  TopicId             Int?
  DifficultyId        Int?
  TypeId              Int?
  QuestionContent     String?
  Explanation         String?
  CreatedAt           DateTime?             @default(now())
  AttemptQuestions    AttemptQuestions[]
  ExamQuestions       ExamQuestions[]
  QuestionImages      QuestionImages[]
  QuestionOptions     QuestionOptions[]
  DifficultyLevels    DifficultyLevels?     @relation(fields: [DifficultyId], references: [DifficultyId], onDelete: NoAction, onUpdate: NoAction)
  Topics              Topics?               @relation(fields: [TopicId], references: [TopicId], onDelete: NoAction, onUpdate: NoAction)
  QuestionTypes       QuestionTypes?        @relation(fields: [TypeId], references: [TypeId], onDelete: NoAction, onUpdate: NoAction)
  QuestionSkills      QuestionSkills[]
  ShortAnswers        ShortAnswers[]
  TrueFalseStatements TrueFalseStatements[]
}

model QuestionSkills {
  QuestionId Int       @default(autoincrement())
  SkillId    Int
  Questions  Questions @relation(fields: [QuestionId], references: [QuestionId], onUpdate: NoAction)
  Skills     Skills    @relation(fields: [SkillId], references: [SkillId], onUpdate: NoAction)

  @@id([QuestionId, SkillId])
}

model QuestionTypes {
  TypeId    Int         @id @default(autoincrement())
  TypeName  String?
  Questions Questions[]
}

model ShortAnswers {
  AnswerId      Int        @id @default(autoincrement())
  QuestionId    Int?
  CorrectAnswer String?
  Questions     Questions? @relation(fields: [QuestionId], references: [QuestionId], onDelete: NoAction, onUpdate: NoAction)
}

model Skills {
  SkillId               Int                     @id @default(autoincrement())
  TopicId               Int?
  SkillName             String?
  AnalyticsSkillResults AnalyticsSkillResults[]
  QuestionSkills        QuestionSkills[]
  Topics                Topics?                 @relation(fields: [TopicId], references: [TopicId], onDelete: NoAction, onUpdate: NoAction)
}

model StudentAnswers {
  Id                Int               @id @default(autoincrement())
  AttemptQuestionId Int?
  SelectedOption    String?
  ShortAnswer       String?
  CreatedAt         DateTime?         @default(now())
  AttemptQuestions  AttemptQuestions? @relation(fields: [AttemptQuestionId], references: [AttemptQuestionId], onDelete: NoAction, onUpdate: NoAction)
}

model StudentExams {
  StudentExamId         Int                     @id @default(autoincrement())
  StudentId             Int?
  ExamId                Int?
  Score                 Decimal?
  Status                String                  @default("InProgress")
  ExpireAt              DateTime?
  SubmittedAt           DateTime?
  LastSavedAt           DateTime?
  IsAutoSubmitted       Boolean                 @default(false)
  EntryCodeUsed         String?
  AttemptNo             Int                     @default(1)
  FilePath              String?
  CreatedAt             DateTime                @default(now())
  UpdatedAt             DateTime?
  AnalyticsSkillResults AnalyticsSkillResults[]
  AnalyticsTopicResults AnalyticsTopicResults[]
  AttemptQuestions      AttemptQuestions[]
  ExamBehaviorLogs      ExamBehaviorLogs[]
  Exams                 Exams?                  @relation(fields: [ExamId], references: [ExamId], onDelete: NoAction, onUpdate: NoAction)
  Students              Students?               @relation(fields: [StudentId], references: [StudentId], onDelete: NoAction, onUpdate: NoAction)
}

model Classes {
  ClassId    Int       @id @default(autoincrement())
  ClassName  String
  CreatedAt  DateTime? @default(now())
  is_deleted Boolean   @default(false)

  Students Students[]
}

model Students {
  StudentId  Int       @id @default(autoincrement())
  ClassId    Int?
  FullName   String?
  Email      String?
  Password   String?
  CreatedAt  DateTime? @default(now())
  is_deleted Boolean   @default(false)

  Class        Classes?       @relation(fields: [ClassId], references: [ClassId])
  StudentExams StudentExams[]
}

model Topics {
  TopicId               Int                     @id @default(autoincrement())
  TopicName             String?
  AnalyticsTopicResults AnalyticsTopicResults[]
  Questions             Questions[]
  Skills                Skills[]
}

model TrueFalseStatements {
  StatementId      Int        @id @default(autoincrement())
  QuestionId       Int?
  StatementLabel   String?
  StatementContent String?
  IsCorrect        Boolean?
  Questions        Questions? @relation(fields: [QuestionId], references: [QuestionId], onDelete: NoAction, onUpdate: NoAction)
}
